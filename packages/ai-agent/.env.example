GITHUB_TOKEN=ghp_your_token_here
ANTHROPIC_API_KEY=sk-ant-your_key_here
PORT=3001

# XRPL Settlement (generate testnet wallets with: npx tsx -e "import {generateWallet,fundWallet,disconnect} from '@lapis/xrpl-contracts'; async function go(){const w=generateWallet();await fundWallet(w);console.log(w.seed);await disconnect();}; go()")
FOUNDER_SEED=sEdXXXXXXXXXXXXXXXXXXXXXXX
AGENT_SEED=sEdXXXXXXXXXXXXXXXXXXXXXXX
XRPL_NETWORK=testnet
RLUSD_ISSUER=rMxCKbEDwqr76QuheSUMdEGf4B9xJ8m5De

# API key auth for mutation endpoints (comma-separated, leave empty to disable)
# When set, POST /analyze, POST /market/*, POST /monitor/*, DELETE /monitor/* require a valid key
# via X-API-Key header or Authorization: Bearer header
API_KEYS=

# API auth for escrow release endpoint (use a random secret, NOT a wallet seed)
AGENT_API_SECRET=your_random_secret_here

# XRPL paywall: set to "true" to require X-Payment-Sender header (sender verification)
# PAYWALL_REQUIRE_SENDER=true

# Logging: "debug", "info", "warn", "error" (default: "debug" in dev, "info" in prod)
# LOG_LEVEL=info

# Set to "production" for JSON logging, error message redaction, etc.
# NODE_ENV=production

# Redis URL for persistent storage (optional, falls back to in-memory)
# REDIS_URL=redis://localhost:6379

# MetaLEX SAFE on Base Sepolia (optional -- settlement works without it)
# Get testnet ETH: https://www.alchemy.com/faucets/base-sepolia
BASE_PRIVATE_KEY=0xYOUR_EVM_PRIVATE_KEY_HERE
BASE_RPC_URL=https://sepolia.base.org
